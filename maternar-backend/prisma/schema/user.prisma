model User {
  id                      String        @id @default(uuid()) @db.Uuid
  name                    String
  email                   String        @unique
  password                String
  phone                   String?
  height                  Decimal?
  weight                  Decimal?
  previousPregnancies     Int?          @map("previous_pregnancies")
  educationLevel          Int?          @map("education_level")
  zipCode                 String        @map("zip_code")
  hadPreviousComplication Boolean?      @map("had_previous_complication")
  birthDate               DateTime      @map("birth_date") @db.Date
  createdAt               DateTime      @default(now()) @map("created_at")
  location                UserLocation?

  @@map("users")
}
